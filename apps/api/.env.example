APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/streaming_chat
DATABASE_ECHO=false
REDIS_URL=redis://redis:6379/0
TEMPORAL_TARGET_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=streaming-chat
DBOS_SYSTEM_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/streaming_chat
AZURE_OPENAI_ENDPOINT=https://example-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-me
OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL=gpt-4.1-mini
USE_TEST_MODEL=false
REPLAY_STREAM_TTL_SECONDS=3600
